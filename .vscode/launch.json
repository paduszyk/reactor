{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django (system check)",
      "type": "debugpy",
      "request": "launch",
      "args": ["check"],
      "django": true,
      "program": "${workspaceFolder}/manage.py"
    },
    {
      "name": "Django (development server)",
      "type": "debugpy",
      "request": "launch",
      "args": ["runserver"],
      "django": true,
      "program": "${workspaceFolder}/manage.py"
    },
    {
      "name": "Django (Python shell)",
      "type": "debugpy",
      "request": "launch",
      "args": ["shell"],
      "django": true,
      "program": "${workspaceFolder}/manage.py"
    }
  ]
}
